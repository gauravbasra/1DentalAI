generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkbenchStatus {
  OPEN
  SETUP_REQUIRED
  APPROVAL_LOCKED
  BLOCKED
}

enum WorkbenchActionKind {
  LOCAL_STATE_CHANGE
  APPROVAL_REQUEST
  CONNECTOR_SETUP
  EXTERNAL_EXECUTION_BLOCKED
}

enum WorkbenchAuditOutcome {
  ALLOWED
  BLOCKED
  READ_ONLY
}

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  mode        String   @default("PRODUCTION_SETUP")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  locations   Location[]
  roles       TenantRole[]
  workbenches WorkbenchArea[]
  audits      WorkbenchAuditEvent[]
}

model Location {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  name      String
  timezone  String
  status    String   @default("ONBOARDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items     WorkbenchQueueItem[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
}

model TenantRole {
  id          String   @id @default(cuid())
  tenantId    String
  roleKey     String
  title       String
  scopes      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workbenches WorkbenchAreaRole[]

  @@unique([tenantId, roleKey])
}

model WorkbenchArea {
  id              String            @id @default(cuid())
  tenantId        String
  slug            String
  title           String
  domain          String
  status          WorkbenchStatus
  summary         String
  primarySystem   String
  liveCapability  Boolean           @default(false)
  setupReason     String?
  approvalReason  String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles           WorkbenchAreaRole[]
  queueItems      WorkbenchQueueItem[]
  connectorItems  ConnectorReadinessItem[]
  audits          WorkbenchAuditEvent[]

  @@unique([tenantId, slug])
  @@index([tenantId, domain])
  @@index([tenantId, status])
}

model WorkbenchAreaRole {
  id          String        @id @default(cuid())
  areaId      String
  roleId      String
  accessLevel String        @default("WORK")
  area        WorkbenchArea @relation(fields: [areaId], references: [id], onDelete: Cascade)
  role        TenantRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([areaId, roleId])
}

model WorkbenchQueueItem {
  id              String       @id @default(cuid())
  areaId          String
  tenantId        String
  locationId      String?
  patientRef      String?
  ownerRoleKey    String
  title           String
  detail          String
  status          String
  priority        String
  dueAt           DateTime?
  amountCents     Int?
  sourceSystem    String
  sourceObjectType String
  sourceObjectId  String?
  clinicalData    Json?
  financialData   Json?
  marketingData   Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  area            WorkbenchArea @relation(fields: [areaId], references: [id], onDelete: Cascade)
  location        Location?     @relation(fields: [locationId], references: [id], onDelete: SetNull)
  actions         WorkbenchAction[]

  @@index([tenantId, ownerRoleKey])
  @@index([areaId, priority])
  @@index([locationId])
  @@index([sourceObjectType, sourceObjectId])
}

model WorkbenchAction {
  id              String              @id @default(cuid())
  queueItemId     String
  label           String
  kind            WorkbenchActionKind
  requiresScope   String[]
  externalSystem  String?
  blockedReason   String?
  resultStatus    String              @default("READY")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  queueItem       WorkbenchQueueItem   @relation(fields: [queueItemId], references: [id], onDelete: Cascade)
  audits          WorkbenchAuditEvent[]

  @@index([queueItemId, kind])
}

model ConnectorReadinessItem {
  id                 String          @id @default(cuid())
  areaId             String
  connectorCategory  String
  capability         String
  status             String
  requiredFields     String[]
  missingFields      String[]
  policyGate         String
  nextAction         String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  area               WorkbenchArea   @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@index([areaId, connectorCategory])
  @@index([status])
}

model WorkbenchAuditEvent {
  id          String                  @id @default(cuid())
  tenantId    String
  areaId      String?
  actionId    String?
  actorRole   String
  eventType   String
  outcome     WorkbenchAuditOutcome
  summary     String
  metadata    Json?
  createdAt   DateTime                @default(now())
  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  area        WorkbenchArea?          @relation(fields: [areaId], references: [id], onDelete: SetNull)
  action      WorkbenchAction?        @relation(fields: [actionId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorRole])
  @@index([outcome])
}

model PmsFamilyAccount {
  id            String   @id @default(cuid())
  tenantId      String
  accountNumber String
  displayName   String
  guarantorPatientId String?
  billingType   String   @default("STANDARD")
  billingStatus String   @default("CURRENT")
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  postalCode    String?
  phone         String?
  email         String?
  financialNote String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, accountNumber])
  @@index([tenantId, billingStatus])
}

model PmsPatient {
  id              String    @id @default(cuid())
  tenantId        String
  familyAccountId String?
  chartNumber     String
  firstName       String
  lastName        String
  preferredName   String?
  dateOfBirth     DateTime?
  phone           String?
  email           String?
  sex             String?
  genderIdentity  String?
  preferredProviderId String?
  primaryLocationId String?
  responsibleParty String?
  emergencyContactName String?
  emergencyContactPhone String?
  referralSource  String?
  status          String    @default("ACTIVE")
  privacyLevel    String    @default("STANDARD")
  patientNote     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, chartNumber])
  @@index([tenantId, lastName, firstName])
  @@index([tenantId, status])
}

model PmsProvider {
  id            String   @id @default(cuid())
  tenantId      String
  displayName   String
  providerType  String
  npi           String?
  licenseNumber String?
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, providerType])
  @@index([tenantId, status])
}

model PmsStaffMember {
  id          String   @id @default(cuid())
  tenantId    String
  displayName String
  roleKey     String
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, roleKey])
}

model PmsOperatory {
  id         String   @id @default(cuid())
  tenantId   String
  locationId String
  code       String
  name       String
  status     String   @default("READY")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, locationId, code])
  @@index([tenantId, status])
}

model PmsAppointment {
  id              String   @id @default(cuid())
  tenantId        String
  patientId       String?
  providerId      String?
  operatoryId     String?
  startsAt        DateTime
  endsAt          DateTime
  status          String
  appointmentType String
  productionCents Int      @default(0)
  readinessStatus String   @default("NEEDS_REVIEW")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, startsAt])
  @@index([tenantId, providerId, startsAt])
  @@index([tenantId, operatoryId, startsAt])
  @@index([tenantId, status])
}

model PmsAppointmentCategory {
  id                  String   @id @default(cuid())
  tenantId            String
  name                String
  color               String
  defaultMinutes      Int
  productionType      String
  defaultProcedureCodes String[]
  providerType        String?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, active])
}

model PmsBlockout {
  id          String   @id @default(cuid())
  tenantId    String
  operatoryId String?
  providerId  String?
  startsAt    DateTime
  endsAt      DateTime
  reason      String
  blockType   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, startsAt])
  @@index([operatoryId, startsAt])
}

model PmsAppointmentStatusHistory {
  id            String   @id @default(cuid())
  appointmentId String
  status        String
  actorRole     String
  note          String?
  createdAt     DateTime @default(now())

  @@index([appointmentId, createdAt])
}

model PmsAppointmentRequest {
  id              String   @id @default(cuid())
  tenantId        String
  patientId       String?
  requestType     String
  source          String
  preferredWindow String?
  urgency         String
  status          String   @default("OPEN")
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status, urgency])
}

model PmsRecall {
  id           String   @id @default(cuid())
  tenantId     String
  patientId    String
  recallType   String
  dueDate      DateTime
  status       String   @default("DUE")
  procedureCodes String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, status, dueDate])
  @@index([patientId, recallType])
}

model PmsProcedureCode {
  id              String   @id @default(cuid())
  tenantId        String
  code            String
  description     String
  category        String
  defaultFeeCents Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, category])
}

model PmsAppointmentProcedure {
  id              String   @id @default(cuid())
  appointmentId   String
  procedureCodeId String
  tooth           String?
  surface         String?
  feeCents        Int      @default(0)
  status          String   @default("PLANNED")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([appointmentId])
}

model PmsMedicalAlert {
  id        String   @id @default(cuid())
  patientId String
  severity  String
  title     String
  details   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, active])
}

model PmsMedication {
  id        String   @id @default(cuid())
  patientId String
  name      String
  dosage    String?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, status])
}

model PmsAllergy {
  id        String   @id @default(cuid())
  patientId String
  allergen  String
  reaction  String?
  severity  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, active])
}

model PmsClinicalNote {
  id         String    @id @default(cuid())
  patientId  String
  providerId String?
  noteType   String
  status     String    @default("DRAFT")
  body       String
  signedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([patientId, createdAt])
  @@index([providerId, status])
}

model PmsToothCondition {
  id        String   @id @default(cuid())
  patientId String
  tooth     String
  surface   String?
  condition String
  status    String
  source    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, tooth])
}

model PmsProcedureLog {
  id              String    @id @default(cuid())
  patientId       String
  providerId      String?
  procedureCodeId String
  tooth           String?
  surface         String?
  status          String
  feeCents        Int       @default(0)
  serviceDate     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([patientId, status])
  @@index([providerId, serviceDate])
}

model PmsPerioExam {
  id            String   @id @default(cuid())
  patientId     String
  providerId    String?
  examDate      DateTime @default(now())
  status        String   @default("IN_PROGRESS")
  diagnosis     String?
  bleedingScore Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([patientId, examDate])
}

model PmsPerioMeasure {
  id           String   @id @default(cuid())
  perioExamId  String
  tooth        String
  site         String
  probingDepth Int
  bleeding     Boolean  @default(false)
  recession    Int?
  mobility     String?
  furcation    String?
  createdAt    DateTime @default(now())

  @@unique([perioExamId, tooth, site])
}

model PmsTreatmentPlan {
  id             String   @id @default(cuid())
  tenantId       String
  patientId      String
  providerId     String?
  name           String
  presentationNote String?
  acceptedAt     DateTime?
  signedAt       DateTime?
  status         String   @default("DRAFT")
  totalFeeCents  Int      @default(0)
  patientEstimateCents Int @default(0)
  insuranceEstimateCents Int @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, status])
  @@index([patientId, status])
}

model PmsTreatmentPlanItem {
  id              String   @id @default(cuid())
  treatmentPlanId String
  procedureCodeId String
  phase           Int      @default(1)
  sequence        Int
  tooth           String?
  surface         String?
  feeCents        Int      @default(0)
  insuranceEstimateCents Int @default(0)
  patientEstimateCents Int @default(0)
  status          String   @default("PROPOSED")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([treatmentPlanId, sequence])
}

model PmsInsurancePlan {
  id          String   @id @default(cuid())
  tenantId    String
  payerName   String
  payerId     String?
  planName    String
  planType    String   @default("PPO")
  groupNumber String?
  employerName String?
  effectiveDate DateTime?
  terminationDate DateTime?
  networkStatus String @default("UNKNOWN")
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, payerName])
  @@index([tenantId, status])
}

model PmsPatientInsurance {
  id            String   @id @default(cuid())
  patientId     String
  planId        String
  subscriberId  String
  memberNumber  String?
  employer      String?
  relationship  String
  priority      Int
  eligibilityStatus String @default("NOT_CHECKED")
  lastVerifiedAt DateTime?
  verificationNote String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([patientId, priority])
  @@index([planId, eligibilityStatus])
}

model PmsBenefitSummary {
  id                 String   @id @default(cuid())
  patientInsuranceId String
  benefitYear        Int
  deductibleCents    Int      @default(0)
  deductibleMetCents Int      @default(0)
  annualMaxCents     Int      @default(0)
  annualUsedCents    Int      @default(0)
  frequencies        Json?
  limitations        Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([patientInsuranceId, benefitYear])
}

model PmsClaim {
  id              String   @id @default(cuid())
  tenantId        String
  patientId       String
  patientInsuranceId String?
  appointmentId   String?
  payerName       String
  claimNumber     String?
  clearinghouseTraceId String?
  attachmentStatus String @default("NOT_REQUIRED")
  status          String
  billedCents     Int      @default(0)
  allowedCents    Int      @default(0)
  paidCents       Int      @default(0)
  patientDueCents Int      @default(0)
  submittedAt     DateTime?
  lastStatusAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status])
  @@index([patientId, createdAt])
  @@index([patientInsuranceId, status])
}

model PmsClaimLine {
  id              String   @id @default(cuid())
  claimId         String
  procedureLogId  String?
  procedureCodeId String
  tooth           String?
  surface         String?
  serviceDate     DateTime?
  feeCents        Int      @default(0)
  allowedCents    Int      @default(0)
  paidCents       Int      @default(0)
  patientDueCents Int      @default(0)
  status          String   @default("READY")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([claimId, status])
  @@index([procedureLogId])
}

model PmsLedgerEntry {
  id            String   @id @default(cuid())
  tenantId      String
  patientId     String
  claimId       String?
  procedureLogId String?
  treatmentPlanId String?
  entryType     String
  description   String
  amountCents   Int
  balanceCents  Int      @default(0)
  status        String   @default("POSTED")
  serviceDate   DateTime?
  postedAt      DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([tenantId, postedAt])
  @@index([patientId, postedAt])
  @@index([claimId, entryType])
}

model PmsPayment {
  id          String   @id @default(cuid())
  tenantId    String
  patientId   String
  ledgerEntryId String?
  paymentType String
  amountCents Int
  reference   String?
  unappliedCents Int @default(0)
  status      String
  postedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([tenantId, postedAt])
  @@index([patientId, postedAt])
}

model PmsLedgerAdjustment {
  id             String   @id @default(cuid())
  tenantId       String
  patientId      String
  ledgerEntryId  String?
  adjustmentType String
  reason         String
  amountCents    Int
  status         String   @default("POSTED")
  createdAt      DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([patientId, createdAt])
}

model PmsStatement {
  id              String   @id @default(cuid())
  tenantId        String
  patientId       String
  familyAccountId String?
  statementDate   DateTime @default(now())
  totalCents      Int      @default(0)
  status          String   @default("DRAFT")
  deliveryMethod  String   @default("PORTAL")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status])
  @@index([patientId, statementDate])
}

model PmsDocument {
  id             String   @id @default(cuid())
  tenantId       String
  patientId      String?
  claimId        String?
  appointmentId  String?
  documentType   String
  title          String
  storageUri     String?
  status         String   @default("REQUIRED")
  signatureStatus String  @default("NOT_REQUIRED")
  sourceModule   String?
  reviewedByRole String?
  reviewedAt     DateTime?
  expiresAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, status])
  @@index([patientId, documentType])
  @@index([claimId, documentType])
}

model PmsImagingStudy {
  id                String   @id @default(cuid())
  tenantId          String
  patientId         String
  providerId        String?
  appointmentId     String?
  studyType         String
  acquisitionStatus String   @default("ORDERED")
  tooth             String?
  region            String?
  dicomStudyUid     String?
  storageUri        String?
  findings          String?
  aiReviewStatus    String   @default("NOT_REQUESTED")
  takenAt           DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId, acquisitionStatus])
  @@index([patientId, takenAt])
}

model PmsPrescription {
  id             String   @id @default(cuid())
  tenantId       String
  patientId      String
  providerId     String?
  medicationName String
  dosage         String?
  directions     String
  quantity       String?
  refills        Int      @default(0)
  pharmacyName   String?
  pharmacyPhone  String?
  status         String   @default("DRAFT")
  writtenAt      DateTime @default(now())
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, status])
  @@index([patientId, writtenAt])
}

model PmsReferral {
  id                  String   @id @default(cuid())
  tenantId            String
  patientId           String
  providerId          String?
  referralType        String
  referredToName      String
  referredToSpecialty String?
  referredToPhone     String?
  reason              String
  status              String   @default("DRAFT")
  dueAt               DateTime?
  sentAt              DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId, status])
  @@index([patientId, createdAt])
}

model PmsLabCase {
  id            String   @id @default(cuid())
  tenantId      String
  patientId     String?
  appointmentId String?
  labName       String
  caseType      String
  status        String   @default("ORDERED")
  dueDate       DateTime?
  trackingNumber String?
  shade         String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, status, dueDate])
  @@index([appointmentId])
}

model PmsTask {
  id            String   @id @default(cuid())
  tenantId      String
  patientId     String?
  appointmentId String?
  ownerRoleKey  String
  title         String
  taskType      String
  status        String   @default("OPEN")
  priority      String   @default("NORMAL")
  dueAt         DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, ownerRoleKey, status])
  @@index([tenantId, dueAt])
}

model PatientEngagementEvent {
  id             String   @id @default(cuid())
  tenantId       String
  patientId      String
  appointmentId  String?
  procedureLogId String?
  sourceModule   String
  eventType      String
  channel        String
  status         String   @default("DRAFT")
  triggerReason  String
  messageBody    String
  approvalStatus String   @default("NEEDS_REVIEW")
  scheduledFor   DateTime?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, status, scheduledFor])
  @@index([patientId, eventType])
  @@index([appointmentId])
}

model ReputationRecoveryCase {
  id                   String   @id @default(cuid())
  tenantId             String
  patientId            String
  appointmentId         String?
  sourceEventId         String?
  sentiment             String
  status                String   @default("OPEN")
  ownerRoleKey          String   @default("practice_manager")
  reason                String
  recoveryNote          String?
  reviewRequestBlocked  Boolean  @default(true)
  dueAt                 DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([tenantId, status, dueAt])
  @@index([patientId, status])
  @@index([sourceEventId])
}

model PmsAuditEvent {
  id        String   @id @default(cuid())
  tenantId  String
  actorRole String
  eventType String
  targetType String
  targetId  String?
  outcome   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([targetType, targetId])
}
