generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkbenchStatus {
  OPEN
  SETUP_REQUIRED
  APPROVAL_LOCKED
  BLOCKED
}

enum WorkbenchActionKind {
  LOCAL_STATE_CHANGE
  APPROVAL_REQUEST
  CONNECTOR_SETUP
  EXTERNAL_EXECUTION_BLOCKED
}

enum WorkbenchAuditOutcome {
  ALLOWED
  BLOCKED
  READ_ONLY
}

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  mode        String   @default("PRODUCTION_SETUP")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  locations   Location[]
  roles       TenantRole[]
  workbenches WorkbenchArea[]
  audits      WorkbenchAuditEvent[]
}

model Location {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  name      String
  timezone  String
  status    String   @default("ONBOARDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items     WorkbenchQueueItem[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
}

model TenantRole {
  id          String   @id @default(cuid())
  tenantId    String
  roleKey     String
  title       String
  scopes      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workbenches WorkbenchAreaRole[]

  @@unique([tenantId, roleKey])
}

model WorkbenchArea {
  id              String            @id @default(cuid())
  tenantId        String
  slug            String
  title           String
  domain          String
  status          WorkbenchStatus
  summary         String
  primarySystem   String
  liveCapability  Boolean           @default(false)
  setupReason     String?
  approvalReason  String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles           WorkbenchAreaRole[]
  queueItems      WorkbenchQueueItem[]
  connectorItems  ConnectorReadinessItem[]
  audits          WorkbenchAuditEvent[]

  @@unique([tenantId, slug])
  @@index([tenantId, domain])
  @@index([tenantId, status])
}

model WorkbenchAreaRole {
  id          String        @id @default(cuid())
  areaId      String
  roleId      String
  accessLevel String        @default("WORK")
  area        WorkbenchArea @relation(fields: [areaId], references: [id], onDelete: Cascade)
  role        TenantRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([areaId, roleId])
}

model WorkbenchQueueItem {
  id              String       @id @default(cuid())
  areaId          String
  tenantId        String
  locationId      String?
  patientRef      String?
  ownerRoleKey    String
  title           String
  detail          String
  status          String
  priority        String
  dueAt           DateTime?
  amountCents     Int?
  sourceSystem    String
  sourceObjectType String
  sourceObjectId  String?
  clinicalData    Json?
  financialData   Json?
  marketingData   Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  area            WorkbenchArea @relation(fields: [areaId], references: [id], onDelete: Cascade)
  location        Location?     @relation(fields: [locationId], references: [id], onDelete: SetNull)
  actions         WorkbenchAction[]

  @@index([tenantId, ownerRoleKey])
  @@index([areaId, priority])
  @@index([locationId])
  @@index([sourceObjectType, sourceObjectId])
}

model WorkbenchAction {
  id              String              @id @default(cuid())
  queueItemId     String
  label           String
  kind            WorkbenchActionKind
  requiresScope   String[]
  externalSystem  String?
  blockedReason   String?
  resultStatus    String              @default("READY")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  queueItem       WorkbenchQueueItem   @relation(fields: [queueItemId], references: [id], onDelete: Cascade)
  audits          WorkbenchAuditEvent[]

  @@index([queueItemId, kind])
}

model ConnectorReadinessItem {
  id                 String          @id @default(cuid())
  areaId             String
  connectorCategory  String
  capability         String
  status             String
  requiredFields     String[]
  missingFields      String[]
  policyGate         String
  nextAction         String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  area               WorkbenchArea   @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@index([areaId, connectorCategory])
  @@index([status])
}

model ConnectorDefinition {
  id              String   @id @default(cuid())
  tenantId        String
  slug            String
  name            String
  category        String
  vendorType      String   @default("DIRECT_OR_VENDOR")
  status          String   @default("AVAILABLE")
  summary         String
  dataClasses     String[] @default([])
  supportedScopes String[] @default([])
  setupChecklist  Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  installations ConnectorInstallation[]
  capabilities  ConnectorCapability[]
  routeDecisions ConnectorRouteDecision[]
  healthChecks  ConnectorHealthCheck[]
  costEvents    ConnectorCostEvent[]

  @@unique([tenantId, slug])
  @@index([tenantId, category, status])
}

model ConnectorInstallation {
  id             String   @id @default(cuid())
  tenantId       String
  definitionId   String
  locationId     String?
  status         String   @default("SETUP_REQUIRED")
  credentialStatus String @default("MISSING")
  webhookStatus  String   @default("NOT_CONFIGURED")
  approvalStatus String   @default("NEEDS_APPROVAL")
  healthStatus   String   @default("NOT_TESTED")
  fallbackMode   String   @default("MANUAL_QUEUE")
  costPolicy     Json?
  nextAction     String
  lastHealthyAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  definition ConnectorDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  capabilities ConnectorCapability[]
  routeDecisions ConnectorRouteDecision[]
  healthChecks ConnectorHealthCheck[]
  costEvents ConnectorCostEvent[]

  @@index([tenantId, status, healthStatus])
  @@index([definitionId, locationId])
}

model ConnectorCredentialVault {
  id              String   @id @default(cuid())
  tenantId        String
  definitionId    String?
  installationId  String?
  providerKey     String
  credentialLabel String
  credentialType  String
  status          String   @default("STORED_PENDING_VALIDATION")
  encryptedValue  String
  encryptionIv    String
  encryptionTag   String
  fingerprint     String
  lastFour        String?
  createdByRole   String   @default("support_admin")
  rotatedAt       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, providerKey, status])
  @@index([installationId, status])
  @@unique([tenantId, installationId, providerKey, credentialLabel])
}

model ConnectorCapability {
  id             String   @id @default(cuid())
  tenantId       String
  definitionId   String
  installationId String?
  capabilityKey  String
  workflowArea   String
  direction      String
  status         String   @default("NOT_CONFIGURED")
  supportedTransactions String[] @default([])
  requiredFields String[] @default([])
  missingFields  String[] @default([])
  approvalPolicy Json?
  fallbackPolicy Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  definition ConnectorDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  installation ConnectorInstallation? @relation(fields: [installationId], references: [id], onDelete: SetNull)

  @@index([tenantId, workflowArea, status])
  @@index([definitionId, capabilityKey])
}

model ConnectorRouteDecision {
  id             String   @id @default(cuid())
  tenantId       String
  definitionId   String?
  installationId String?
  workflowArea   String
  sourceObjectType String
  sourceObjectId String?
  requestedCapability String
  routeStatus    String   @default("BLOCKED_CONNECTOR_REQUIRED")
  selectedRoute  String?
  fallbackRoute  String   @default("MANUAL_QUEUE")
  estimatedCostCents Int  @default(0)
  blockedReason  String?
  decisionContext Json?
  actorRole      String   @default("system")
  createdAt      DateTime @default(now())

  definition ConnectorDefinition? @relation(fields: [definitionId], references: [id], onDelete: SetNull)
  installation ConnectorInstallation? @relation(fields: [installationId], references: [id], onDelete: SetNull)

  @@index([tenantId, workflowArea, createdAt])
  @@index([sourceObjectType, sourceObjectId])
}

model ConnectorHealthCheck {
  id             String   @id @default(cuid())
  tenantId       String
  definitionId   String
  installationId String?
  checkType      String
  status         String
  resultSummary  String
  latencyMs      Int?
  checkedAt      DateTime @default(now())

  definition ConnectorDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  installation ConnectorInstallation? @relation(fields: [installationId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, checkedAt])
  @@index([definitionId, checkType])
}

model ConnectorCostEvent {
  id             String   @id @default(cuid())
  tenantId       String
  definitionId   String?
  installationId String?
  workflowArea   String
  capabilityKey  String
  sourceObjectType String?
  sourceObjectId String?
  costCents      Int      @default(0)
  pricingUnit    String
  status         String   @default("ESTIMATED")
  metadata       Json?
  createdAt      DateTime @default(now())

  definition ConnectorDefinition? @relation(fields: [definitionId], references: [id], onDelete: SetNull)
  installation ConnectorInstallation? @relation(fields: [installationId], references: [id], onDelete: SetNull)

  @@index([tenantId, workflowArea, createdAt])
  @@index([definitionId, capabilityKey])
}

model WorkbenchAuditEvent {
  id          String                  @id @default(cuid())
  tenantId    String
  areaId      String?
  actionId    String?
  actorRole   String
  eventType   String
  outcome     WorkbenchAuditOutcome
  summary     String
  metadata    Json?
  createdAt   DateTime                @default(now())
  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  area        WorkbenchArea?          @relation(fields: [areaId], references: [id], onDelete: SetNull)
  action      WorkbenchAction?        @relation(fields: [actionId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorRole])
  @@index([outcome])
}

model PmsFamilyAccount {
  id            String   @id @default(cuid())
  tenantId      String
  accountNumber String
  displayName   String
  guarantorPatientId String?
  billingType   String   @default("STANDARD")
  billingStatus String   @default("CURRENT")
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  postalCode    String?
  phone         String?
  email         String?
  financialNote String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, accountNumber])
  @@index([tenantId, billingStatus])
}

model PmsPatient {
  id              String    @id @default(cuid())
  tenantId        String
  familyAccountId String?
  chartNumber     String
  firstName       String
  lastName        String
  preferredName   String?
  dateOfBirth     DateTime?
  phone           String?
  email           String?
  sex             String?
  genderIdentity  String?
  preferredProviderId String?
  primaryLocationId String?
  responsibleParty String?
  emergencyContactName String?
  emergencyContactPhone String?
  referralSource  String?
  status          String    @default("ACTIVE")
  privacyLevel    String    @default("STANDARD")
  patientNote     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, chartNumber])
  @@index([tenantId, lastName, firstName])
  @@index([tenantId, status])
}

model PmsProvider {
  id            String   @id @default(cuid())
  tenantId      String
  displayName   String
  providerType  String
  npi           String?
  licenseNumber String?
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, providerType])
  @@index([tenantId, status])
}

model PmsStaffMember {
  id          String   @id @default(cuid())
  tenantId    String
  displayName String
  roleKey     String
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, roleKey])
}

model PmsOperatory {
  id         String   @id @default(cuid())
  tenantId   String
  locationId String
  code       String
  name       String
  status     String   @default("READY")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, locationId, code])
  @@index([tenantId, status])
}

model PmsAppointment {
  id              String   @id @default(cuid())
  tenantId        String
  patientId       String?
  providerId      String?
  operatoryId     String?
  startsAt        DateTime
  endsAt          DateTime
  status          String
  appointmentType String
  productionCents Int      @default(0)
  readinessStatus String   @default("NEEDS_REVIEW")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, startsAt])
  @@index([tenantId, providerId, startsAt])
  @@index([tenantId, operatoryId, startsAt])
  @@index([tenantId, status])
}

model PmsAppointmentCategory {
  id                  String   @id @default(cuid())
  tenantId            String
  name                String
  color               String
  defaultMinutes      Int
  productionType      String
  defaultProcedureCodes String[]
  providerType        String?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, active])
}

model PmsBlockout {
  id          String   @id @default(cuid())
  tenantId    String
  operatoryId String?
  providerId  String?
  startsAt    DateTime
  endsAt      DateTime
  reason      String
  blockType   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, startsAt])
  @@index([operatoryId, startsAt])
}

model PmsAppointmentStatusHistory {
  id            String   @id @default(cuid())
  appointmentId String
  status        String
  actorRole     String
  note          String?
  createdAt     DateTime @default(now())

  @@index([appointmentId, createdAt])
}

model PmsCheckoutSession {
  id                    String   @id @default(cuid())
  tenantId              String
  appointmentId         String
  patientId             String
  actorRole             String
  status                String   @default("COMPLETED")
  completedProcedureIds String[]
  readinessOverride     Boolean  @default(false)
  blockerSummary        Json?
  chargeCents           Int      @default(0)
  patientPaymentCents   Int      @default(0)
  claimId               String?
  paymentId             String?
  checkoutNote          String?
  createdAt             DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([appointmentId, createdAt])
  @@index([patientId, createdAt])
}

model PmsAppointmentRequest {
  id              String   @id @default(cuid())
  tenantId        String
  patientId       String?
  requestType     String
  source          String
  preferredWindow String?
  urgency         String
  status          String   @default("OPEN")
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status, urgency])
}

model PmsOnlineSchedulingLink {
  id                    String   @id @default(cuid())
  tenantId              String
  slug                  String
  title                 String
  audience              String   @default("ALL_PATIENTS")
  sourceChannel         String   @default("WEBSITE")
  status                String   @default("ACTIVE")
  appointmentCategoryId String?
  providerId            String?
  locationId            String?
  earliestBookingDays   Int      @default(1)
  maxBookingDays        Int      @default(21)
  slotIntervalMinutes   Int      @default(30)
  reservationFeeCents   Int      @default(0)
  requiresInsurance     Boolean  @default(false)
  acceptedPayerNames    Json?
  patientTypePolicy     String   @default("ASK")
  requireSmsVerification Boolean @default(false)
  publicFlowConfig      Json?
  intakeQuestionSchema  Json?
  confirmationPolicy    Json?
  brandingJson          Json?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, status, sourceChannel])
  @@index([appointmentCategoryId, providerId])
}

model PmsOnlineBooking {
  id                    String   @id @default(cuid())
  tenantId              String
  linkId                String
  appointmentId         String?
  patientId             String?
  firstName             String
  lastName              String
  dateOfBirth           DateTime?
  phone                 String?
  email                 String?
  isReturningPatient    Boolean  @default(false)
  appointmentCategoryId String?
  providerId            String?
  operatoryId           String?
  startsAt              DateTime
  endsAt                DateTime
  status                String   @default("BOOKED")
  patientNote           String?
  insurancePayerName    String?
  subscriberId          String?
  eligibilityStatus     String   @default("NOT_CHECKED")
  reservationFeeCents   Int      @default(0)
  reservationPaymentStatus String @default("NOT_REQUIRED")
  sourceChannel         String   @default("WEBSITE")
  utmSource             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([tenantId, createdAt])
  @@index([linkId, status])
  @@index([patientId, startsAt])
  @@index([appointmentId])
}

model PmsSchedulingInviteCampaign {
  id                  String   @id @default(cuid())
  tenantId            String
  linkId              String
  name                String
  audienceFilter      String
  channel             String
  status              String   @default("DRAFT")
  earliestBookingDate DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId, status, channel])
  @@index([linkId])
}

model PmsSchedulingInviteRecipient {
  id            String   @id @default(cuid())
  tenantId      String
  campaignId    String
  patientId     String
  status        String   @default("STAGED")
  clickedAt     DateTime?
  bookedAt      DateTime?
  appointmentId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([campaignId, status])
  @@index([patientId, status])
}

model PmsRecall {
  id           String   @id @default(cuid())
  tenantId     String
  patientId    String
  recallType   String
  dueDate      DateTime
  status       String   @default("DUE")
  procedureCodes String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, status, dueDate])
  @@index([patientId, recallType])
}

model PmsProcedureCode {
  id              String   @id @default(cuid())
  tenantId        String
  code            String
  description     String
  category        String
  defaultFeeCents Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, category])
}

model PmsAppointmentProcedure {
  id              String   @id @default(cuid())
  appointmentId   String
  procedureCodeId String
  tooth           String?
  surface         String?
  feeCents        Int      @default(0)
  status          String   @default("PLANNED")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([appointmentId])
}

model PmsMedicalAlert {
  id        String   @id @default(cuid())
  patientId String
  severity  String
  title     String
  details   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, active])
}

model PmsMedication {
  id        String   @id @default(cuid())
  patientId String
  name      String
  dosage    String?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, status])
}

model PmsAllergy {
  id        String   @id @default(cuid())
  patientId String
  allergen  String
  reaction  String?
  severity  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, active])
}

model PmsPatientCommunicationPreference {
  id            String   @id @default(cuid())
  patientId     String
  channel       String
  destination   String
  consentStatus String   @default("UNKNOWN")
  priority      Int      @default(1)
  quietHoursStart String?
  quietHoursEnd   String?
  source        String?
  lastConfirmedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([patientId, channel])
  @@unique([patientId, channel, destination])
}

model PmsPatientConsent {
  id             String   @id @default(cuid())
  patientId      String
  consentType    String
  status         String   @default("NEEDS_SIGNATURE")
  sourceDocumentId String?
  signedByName   String?
  signedAt       DateTime?
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([patientId, consentType, status])
}

model PmsMedicalHistoryEntry {
  id          String   @id @default(cuid())
  patientId   String
  category    String
  condition   String
  status      String   @default("ACTIVE")
  severity    String?
  onsetDate   DateTime?
  resolvedDate DateTime?
  notes       String?
  source      String   @default("STAFF_ENTERED")
  reviewedByRole String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([patientId, category, status])
}

model PmsPatientPharmacy {
  id          String   @id @default(cuid())
  patientId   String
  pharmacyName String
  phone       String?
  fax         String?
  addressLine1 String?
  city        String?
  state       String?
  postalCode  String?
  isPreferred Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([patientId, isPreferred])
}

model PmsFormTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  formType    String
  version     Int      @default(1)
  status      String   @default("ACTIVE")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, name, version])
  @@index([tenantId, formType, status])
}

model PmsFormField {
  id          String   @id @default(cuid())
  templateId  String
  fieldKey    String
  label       String
  fieldType   String
  required    Boolean  @default(false)
  options     Json?
  displayOrder Int
  helpText    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([templateId, fieldKey])
  @@index([templateId, displayOrder])
}

model PmsFormFieldMapping {
  id          String   @id @default(cuid())
  fieldId     String
  targetModel String
  targetField String
  transformRule String?
  reviewRequired Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([fieldId, targetModel, targetField])
}

model PmsFormAssignment {
  id          String   @id @default(cuid())
  tenantId    String
  patientId   String
  templateId  String
  appointmentId String?
  status      String   @default("ASSIGNED")
  assignedByRole String
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status, dueAt])
  @@index([patientId, status])
}

model PmsFormResponse {
  id          String   @id @default(cuid())
  assignmentId String
  patientId   String
  submittedByName String?
  submittedByType String @default("STAFF_KIOSK")
  status      String   @default("SUBMITTED")
  signatureName String?
  signatureAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([assignmentId, status])
  @@index([patientId, createdAt])
}

model PmsFormResponseAnswer {
  id          String   @id @default(cuid())
  responseId  String
  fieldId     String
  fieldKey    String
  answerValue String
  createdAt   DateTime @default(now())

  @@unique([responseId, fieldId])
  @@index([fieldKey])
}

model PmsProfileChangeRequest {
  id          String   @id @default(cuid())
  tenantId    String
  patientId   String
  responseId  String?
  fieldId     String?
  targetModel String
  targetField String
  currentValue String?
  proposedValue String
  status      String   @default("PENDING")
  reviewNote  String?
  reviewedByRole String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status, createdAt])
