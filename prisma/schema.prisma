generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkbenchStatus {
  OPEN
  SETUP_REQUIRED
  APPROVAL_LOCKED
  BLOCKED
}

enum WorkbenchActionKind {
  LOCAL_STATE_CHANGE
  APPROVAL_REQUEST
  CONNECTOR_SETUP
  EXTERNAL_EXECUTION_BLOCKED
}

enum WorkbenchAuditOutcome {
  ALLOWED
  BLOCKED
  READ_ONLY
}

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  mode        String   @default("PRODUCTION_SETUP")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  locations   Location[]
  roles       TenantRole[]
  workbenches WorkbenchArea[]
  audits      WorkbenchAuditEvent[]
}

model Location {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  name      String
  timezone  String
  status    String   @default("ONBOARDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items     WorkbenchQueueItem[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
}

model TenantRole {
  id          String   @id @default(cuid())
  tenantId    String
  roleKey     String
  title       String
  scopes      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workbenches WorkbenchAreaRole[]

  @@unique([tenantId, roleKey])
}

model WorkbenchArea {
  id              String            @id @default(cuid())
  tenantId        String
  slug            String
  title           String
  domain          String
  status          WorkbenchStatus
  summary         String
  primarySystem   String
  liveCapability  Boolean           @default(false)
  setupReason     String?
  approvalReason  String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles           WorkbenchAreaRole[]
  queueItems      WorkbenchQueueItem[]
  connectorItems  ConnectorReadinessItem[]
  audits          WorkbenchAuditEvent[]

  @@unique([tenantId, slug])
  @@index([tenantId, domain])
  @@index([tenantId, status])
}

model WorkbenchAreaRole {
  id          String        @id @default(cuid())
  areaId      String
  roleId      String
  accessLevel String        @default("WORK")
  area        WorkbenchArea @relation(fields: [areaId], references: [id], onDelete: Cascade)
  role        TenantRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([areaId, roleId])
}

model WorkbenchQueueItem {
  id              String       @id @default(cuid())
  areaId          String
  tenantId        String
  locationId      String?
  patientRef      String?
  ownerRoleKey    String
  title           String
  detail          String
  status          String
  priority        String
  dueAt           DateTime?
  amountCents     Int?
  sourceSystem    String
  sourceObjectType String
  sourceObjectId  String?
  clinicalData    Json?
  financialData   Json?
  marketingData   Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  area            WorkbenchArea @relation(fields: [areaId], references: [id], onDelete: Cascade)
  location        Location?     @relation(fields: [locationId], references: [id], onDelete: SetNull)
  actions         WorkbenchAction[]

  @@index([tenantId, ownerRoleKey])
  @@index([areaId, priority])
  @@index([locationId])
  @@index([sourceObjectType, sourceObjectId])
}

model WorkbenchAction {
  id              String              @id @default(cuid())
  queueItemId     String
  label           String
  kind            WorkbenchActionKind
  requiresScope   String[]
  externalSystem  String?
  blockedReason   String?
  resultStatus    String              @default("READY")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  queueItem       WorkbenchQueueItem   @relation(fields: [queueItemId], references: [id], onDelete: Cascade)
  audits          WorkbenchAuditEvent[]

  @@index([queueItemId, kind])
}

model ConnectorReadinessItem {
  id                 String          @id @default(cuid())
  areaId             String
  connectorCategory  String
  capability         String
  status             String
  requiredFields     String[]
  missingFields      String[]
  policyGate         String
  nextAction         String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  area               WorkbenchArea   @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@index([areaId, connectorCategory])
  @@index([status])
}

model ConnectorDefinition {
  id              String   @id @default(cuid())
  tenantId        String
  slug            String
  name            String
  category        String
  vendorType      String   @default("DIRECT_OR_VENDOR")
  status          String   @default("AVAILABLE")
  summary         String
  dataClasses     String[] @default([])
  supportedScopes String[] @default([])
  setupChecklist  Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  installations ConnectorInstallation[]
  capabilities  ConnectorCapability[]
  routeDecisions ConnectorRouteDecision[]
  healthChecks  ConnectorHealthCheck[]
  costEvents    ConnectorCostEvent[]

  @@unique([tenantId, slug])
  @@index([tenantId, category, status])
}

model ConnectorInstallation {
  id             String   @id @default(cuid())
  tenantId       String
  definitionId   String
  locationId     String?
  status         String   @default("SETUP_REQUIRED")
  credentialStatus String @default("MISSING")
  webhookStatus  String   @default("NOT_CONFIGURED")
  approvalStatus String   @default("NEEDS_APPROVAL")
  healthStatus   String   @default("NOT_TESTED")
  fallbackMode   String   @default("MANUAL_QUEUE")
  costPolicy     Json?
  nextAction     String
  lastHealthyAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  definition ConnectorDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  capabilities ConnectorCapability[]
  routeDecisions ConnectorRouteDecision[]
  healthChecks ConnectorHealthCheck[]
  costEvents ConnectorCostEvent[]

  @@index([tenantId, status, healthStatus])
  @@index([definitionId, locationId])
}

model ConnectorCredentialVault {
  id              String   @id @default(cuid())
  tenantId        String
  definitionId    String?
  installationId  String?
  providerKey     String
  credentialLabel String
  credentialType  String
  status          String   @default("STORED_PENDING_VALIDATION")
  encryptedValue  String
  encryptionIv    String
  encryptionTag   String
  fingerprint     String
  lastFour        String?
  createdByRole   String   @default("support_admin")
  rotatedAt       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, providerKey, status])
  @@index([installationId, status])
  @@unique([tenantId, installationId, providerKey, credentialLabel])
}

model ZoomNotificationEvent {
  id               String   @id
  tenantId         String   @default("tenant_1dentalai_production")
  event            String
  eventTs          DateTime?
  payload          Json
  signatureStatus  String   @default("NOT_CONFIGURED")
  validationStatus String   @default("NOT_VALIDATION_EVENT")
  sourceIp         String?
  userAgent        String?
  receivedAt       DateTime @default(now())

  @@index([tenantId, receivedAt])
  @@index([event])
}

model ConnectorCapability {
  id             String   @id @default(cuid())
  tenantId       String
  definitionId   String
  installationId String?
  capabilityKey  String
  workflowArea   String
  direction      String
  status         String   @default("NOT_CONFIGURED")
  supportedTransactions String[] @default([])
  requiredFields String[] @default([])
  missingFields  String[] @default([])
  approvalPolicy Json?
  fallbackPolicy Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  definition ConnectorDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  installation ConnectorInstallation? @relation(fields: [installationId], references: [id], onDelete: SetNull)

  @@index([tenantId, workflowArea, status])
  @@index([definitionId, capabilityKey])
}

model ConnectorRouteDecision {
  id             String   @id @default(cuid())
  tenantId       String
  definitionId   String?
  installationId String?
  workflowArea   String
  sourceObjectType String
  sourceObjectId String?
  requestedCapability String
  routeStatus    String   @default("BLOCKED_CONNECTOR_REQUIRED")
  selectedRoute  String?
  fallbackRoute  String   @default("MANUAL_QUEUE")
  estimatedCostCents Int  @default(0)
  blockedReason  String?
  decisionContext Json?
  actorRole      String   @default("system")
  createdAt      DateTime @default(now())

  definition ConnectorDefinition? @relation(fields: [definitionId], references: [id], onDelete: SetNull)
  installation ConnectorInstallation? @relation(fields: [installationId], references: [id], onDelete: SetNull)

  @@index([tenantId, workflowArea, createdAt])
  @@index([sourceObjectType, sourceObjectId])
}

model ConnectorHealthCheck {
  id             String   @id @default(cuid())
  tenantId       String
  definitionId   String
  installationId String?
  checkType      String
  status         String
  resultSummary  String
  latencyMs      Int?
  checkedAt      DateTime @default(now())

  definition ConnectorDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  installation ConnectorInstallation? @relation(fields: [installationId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, checkedAt])
  @@index([definitionId, checkType])
}

model ConnectorCostEvent {
  id             String   @id @default(cuid())
  tenantId       String
  definitionId   String?
  installationId String?
  workflowArea   String
  capabilityKey  String
  sourceObjectType String?
  sourceObjectId String?
  costCents      Int      @default(0)
  pricingUnit    String
  status         String   @default("ESTIMATED")
  metadata       Json?
  createdAt      DateTime @default(now())

  definition ConnectorDefinition? @relation(fields: [definitionId], references: [id], onDelete: SetNull)
  installation ConnectorInstallation? @relation(fields: [installationId], references: [id], onDelete: SetNull)

  @@index([tenantId, workflowArea, createdAt])
  @@index([definitionId, capabilityKey])
}

model PmsConnectorCapability {
  id                 String    @id
  tenantId           String
  connectorInstanceId String
  capabilityKey      String
  resourceType       String
  operation          String
  status             String    @default("UNKNOWN")
  requiresApproval   Boolean   @default(true)
  requiredEvidence   Json      @default("[]")
  lastSmokeTestAt    DateTime?
  lastSmokeTestStatus String?
  lastSmokeTestSummary String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([tenantId, connectorInstanceId, capabilityKey])
  @@index([tenantId, status, operation])
}

model PmsExternalRecordLink {
  id                  String   @id
  tenantId            String
  localType           String
  localId             String
  connectorInstanceId String
  externalType        String
  externalId          String
  externalUrl         String?
  lastSyncedAt        DateTime?
  metadata            Json     @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([tenantId, localType, localId, connectorInstanceId, externalType])
  @@index([tenantId, connectorInstanceId, externalType, externalId])
}

model PmsWritebackJob {
  id                  String    @id
  tenantId            String
  connectorInstanceId String
  capabilityKey       String
  localType           String
  localId             String
  externalType        String
  status              String    @default("PENDING_APPROVAL")
  idempotencyKey      String
  requestedByRole     String
  approvedByRole      String?
  approvedAt          DateTime?
  payload             Json
  evidence            Json      @default("[]")
  blockedReason       String?
  externalResponse    Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, localType, localId])
}

model PmsWritebackAttempt {
  id              String    @id
  tenantId        String
  writebackJobId  String
  status          String
  requestPayload  Json
  responsePayload Json?
  statusCode      Int?
  errorMessage    String?
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?

  @@index([writebackJobId, startedAt])
}

model WorkbenchAuditEvent {
  id          String                  @id @default(cuid())
  tenantId    String
  areaId      String?
  actionId    String?
  actorRole   String
  eventType   String
  outcome     WorkbenchAuditOutcome
  summary     String
  metadata    Json?
  createdAt   DateTime                @default(now())
  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  area        WorkbenchArea?          @relation(fields: [areaId], references: [id], onDelete: SetNull)
  action      WorkbenchAction?        @relation(fields: [actionId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorRole])
  @@index([outcome])
}

model PmsFamilyAccount {
  id            String   @id @default(cuid())
  tenantId      String
  accountNumber String
  displayName   String
  guarantorPatientId String?
  billingType   String   @default("STANDARD")
  billingStatus String   @default("CURRENT")
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  postalCode    String?
  phone         String?
  email         String?
  financialNote String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, accountNumber])
  @@index([tenantId, billingStatus])
}

model PmsPatientGeoCoordinate {
  id              String    @id @default(cuid())
  tenantId        String
  familyAccountId String
  addressHash     String
  formattedAddress String?
  latitude        Decimal?  @db.Decimal(10, 7)
  longitude       Decimal?  @db.Decimal(10, 7)
  precision       String?
  status          String    @default("PENDING")
  source          String    @default("GOOGLE_GEOCODING")
  failureReason   String?
  geocodedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, familyAccountId])
  @@index([tenantId, status])
  @@index([latitude, longitude])
}

model PmsPatientMapSavedSegment {
  id             String   @id @default(cuid())
  tenantId       String
  segmentName    String
  filters        Json
  description    String?
  createdByRole  String
  lastRunAt      DateTime?
  lastPatientCount Int    @default(0)
  lastValueCents Int      @default(0)
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, status])
  @@unique([tenantId, segmentName])
}

model PmsPatientMapReportSnapshot {
  id             String   @id @default(cuid())
  tenantId       String
  segmentId      String?
  reportName     String
  filters        Json
  mappedFamilies Int      @default(0)
  mappedPatients Int      @default(0)
  productionCents Int     @default(0)
  treatmentCents Int      @default(0)
  payload        Json
  createdByRole  String
  createdAt      DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([segmentId])
}

model PmsPatient {
  id              String    @id @default(cuid())
  tenantId        String
  familyAccountId String?
  chartNumber     String
  firstName       String
  lastName        String
  preferredName   String?
  dateOfBirth     DateTime?
  phone           String?
  email           String?
  sex             String?
  genderIdentity  String?
  preferredProviderId String?
  primaryLocationId String?
  responsibleParty String?
  emergencyContactName String?
  emergencyContactPhone String?
  referralSource  String?
  status          String    @default("ACTIVE")
  privacyLevel    String    @default("STANDARD")
  patientNote     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, chartNumber])
  @@index([tenantId, lastName, firstName])
  @@index([tenantId, status])
}

model PmsProvider {
  id            String   @id @default(cuid())
  tenantId      String
  displayName   String
  providerType  String
  npi           String?
  licenseNumber String?
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, providerType])
  @@index([tenantId, status])
}

model PmsStaffMember {
  id          String   @id @default(cuid())
  tenantId    String
  displayName String
  roleKey     String
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, roleKey])
}

model PmsOperatory {
  id         String   @id @default(cuid())
  tenantId   String
  locationId String
  code       String
  name       String
  status     String   @default("READY")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, locationId, code])
  @@index([tenantId, status])
}

model PmsAppointment {
  id              String   @id @default(cuid())
  tenantId        String
  patientId       String?
  providerId      String?
  operatoryId     String?
  startsAt        DateTime
  endsAt          DateTime
  status          String
  appointmentType String
  productionCents Int      @default(0)
  readinessStatus String   @default("NEEDS_REVIEW")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, startsAt])
  @@index([tenantId, providerId, startsAt])
  @@index([tenantId, operatoryId, startsAt])
  @@index([tenantId, status])
}

model PmsVirtualVisit {
  id                String    @id
  tenantId          String
  appointmentId     String
  patientId         String?
  providerId        String?
  provider          String    @default("ZOOM")
  providerMeetingId String
  providerUuid      String?
  topic             String
  startUrl          String?
  joinUrl           String
  password          String?
  status            String    @default("CREATED")
  participantStatus String    @default("NOT_STARTED")
  startedAt         DateTime?
  endedAt           DateTime?
  lastEventAt       DateTime?
  createdByRole     String    @default("front_desk")
  metadata          Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([provider, providerMeetingId])
  @@index([tenantId, appointmentId, createdAt])
  @@index([provider, providerUuid])
}

model PmsAppointmentCategory {
  id                  String   @id @default(cuid())
  tenantId            String
  name                String
  color               String
  defaultMinutes      Int
  productionType      String
  defaultProcedureCodes String[]
  providerType        String?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, active])
}

model PmsBlockout {
  id          String   @id @default(cuid())
  tenantId    String
  operatoryId String?
  providerId  String?
  startsAt    DateTime
  endsAt      DateTime
  reason      String
  blockType   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, startsAt])
  @@index([operatoryId, startsAt])
}

model PmsAppointmentStatusHistory {
  id            String   @id @default(cuid())
  appointmentId String
  status        String
  actorRole     String
  note          String?
  createdAt     DateTime @default(now())

  @@index([appointmentId, createdAt])
}

model PmsCheckoutSession {
  id                    String   @id @default(cuid())
  tenantId              String
  appointmentId         String
  patientId             String
  actorRole             String
  status                String   @default("COMPLETED")
  completedProcedureIds String[]
  readinessOverride     Boolean  @default(false)
  blockerSummary        Json?
  chargeCents           Int      @default(0)
  patientPaymentCents   Int      @default(0)
  claimId               String?
  paymentId             String?
  checkoutNote          String?
  createdAt             DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([appointmentId, createdAt])
  @@index([patientId, createdAt])
}

model PmsAppointmentRequest {
  id              String   @id @default(cuid())
  tenantId        String
  patientId       String?
  requestType     String
  source          String
  preferredWindow String?
  urgency         String
  status          String   @default("OPEN")
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status, urgency])
}

model PmsOnlineSchedulingLink {
  id                    String   @id @default(cuid())
  tenantId              String
  slug                  String
  title                 String
  audience              String   @default("ALL_PATIENTS")
  sourceChannel         String   @default("WEBSITE")
  status                String   @default("ACTIVE")
  appointmentCategoryId String?
  providerId            String?
  locationId            String?
  earliestBookingDays   Int      @default(1)
  maxBookingDays        Int      @default(21)
  slotIntervalMinutes   Int      @default(30)
  reservationFeeCents   Int      @default(0)
  requiresInsurance     Boolean  @default(false)
  acceptedPayerNames    Json?
  patientTypePolicy     String   @default("ASK")
  requireSmsVerification Boolean @default(false)
  publicFlowConfig      Json?
  intakeQuestionSchema  Json?
  confirmationPolicy    Json?
  brandingJson          Json?
  workflowKey           String?  @default("standard_booking")
  workflowName          String?  @default("Standard booking")
  workflowScreenSchema  Json?
  requiredFormTemplateIds String[] @default([])
  customFormDefinitionIds String[] @default([])
  bookingMode           String?  @default("DIRECT_BOOKING")
  patientIdentityPolicy String?  @default("PHONE_EMAIL_DOB")
  screenTheme           Json?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, status, sourceChannel])
  @@index([appointmentCategoryId, providerId])
}

model CustomFormDefinition {
  id               String   @id
  tenantId         String
  formKey          String
  name             String
  formType         String   @default("CUSTOM")
  status           String   @default("DRAFT")
  version          Int      @default(1)
  description      String?
  storageTableName String
  workflowUse      String   @default("GENERAL")
  visibility       String   @default("STAFF_AND_PUBLIC_LINK")
  requiresSignature Boolean @default(false)
  allowAnonymous   Boolean  @default(true)
  successMessage   String?
  createdByRole    String   @default("practice_manager")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([tenantId, formKey, version])
  @@index([tenantId, status, formType])
  @@index([tenantId, workflowUse])
}

model CustomFormField {
  id               String   @id
  tenantId         String
  formDefinitionId String
  fieldKey         String
  label            String
  fieldType        String
  required         Boolean  @default(false)
  placeholder      String?
  helpText         String?
  options          Json?
  validation       Json?
  displayOrder     Int      @default(0)
  conditionalLogic Json?
  pmsTargetModel   String?
  pmsTargetField   String?
  phiCategory      String   @default("ADMINISTRATIVE")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([formDefinitionId, fieldKey])
  @@index([formDefinitionId, displayOrder])
}

model CustomFormSubmission {
  id               String   @id
  tenantId         String
  formDefinitionId String
  storageTableName String
  patientId        String?
  appointmentId    String?
  conversationId   String?
  sourceChannel    String   @default("STAFF")
  submittedByName  String?
  submittedByEmail String?
  submittedByPhone String?
  status           String   @default("SUBMITTED")
  signatureName    String?
  signatureAt      DateTime?
  ipAddress        String?
  userAgent        String?
  rawPayload       Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([formDefinitionId, createdAt])
  @@index([patientId, createdAt])
  @@index([tenantId, status, createdAt])
}

model CustomFormSubmissionValue {
  id               String   @id
  tenantId         String
  submissionId     String
  formDefinitionId String
  fieldId          String?
  fieldKey         String
  fieldType        String
  answerText       String?
  answerJson       Json?
  createdAt        DateTime @default(now())

  @@unique([submissionId, fieldKey])
  @@index([formDefinitionId, fieldKey])
}

model PmsOnlineBooking {
  id                    String   @id @default(cuid())
  tenantId              String
  linkId                String
  appointmentId         String?
  patientId             String?
  firstName             String
  lastName              String
  dateOfBirth           DateTime?
  phone                 String?
  email                 String?
  isReturningPatient    Boolean  @default(false)
  appointmentCategoryId String?
  providerId            String?
  operatoryId           String?
  startsAt              DateTime
  endsAt                DateTime
  status                String   @default("BOOKED")
  patientNote           String?
  insurancePayerName    String?
  subscriberId          String?
  eligibilityStatus     String   @default("NOT_CHECKED")
  reservationFeeCents   Int      @default(0)
